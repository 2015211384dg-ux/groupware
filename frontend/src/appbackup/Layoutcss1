.layout {
    display: flex;
    flex-direction: column;
    height: 100vh;
    background: #f5f7fa;
}

.layout-content {
    display: flex;
    flex: 1;
    overflow: hidden;
}

.main-content {
    flex: 1;
    padding: 24px;
    overflow-y: auto;
    transition: margin-left 0.3s ease;
}

.main-content.sidebar-closed {
    margin-left: -200px;
}

@media (max-width: 768px) {
    .main-content {
        padding: 16px;
    }
}
