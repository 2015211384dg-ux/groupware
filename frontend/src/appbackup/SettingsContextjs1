import React, { createContext, useState, useEffect, useContext } from 'react';
import api from './authService';

const SettingsContext = createContext();

export const useSettings = () => {
    const context = useContext(SettingsContext);
    if (!context) {
        throw new Error('useSettings must be used within SettingsProvider');
    }
    return context;
};

export const SettingsProvider = ({ children }) => {
    const [siteSettings, setSiteSettings] = useState({
        site_name: '그룹웨어',
        site_description: '우리 회사 그룹웨어 시스템',
        max_upload_size: 10,
        session_timeout: 60,
        allow_registration: false,
        require_email_verification: true,
        maintenance_mode: false
    });

    const fetchSettings = async () => {
        try {
            const response = await api.get('/admin/settings');
            const data = response.data.data;
            
            const settings = {
                site_name: data.site_name || '그룹웨어',
                site_description: data.site_description || '우리 회사 그룹웨어 시스템',
                max_upload_size: data.max_upload_size || 10,
                session_timeout: data.session_timeout || 60,
                allow_registration: Boolean(data.allow_registration),
                require_email_verification: Boolean(data.require_email_verification),
                maintenance_mode: Boolean(data.maintenance_mode)
            };
            
            setSiteSettings(settings);
            
            // 브라우저 탭 제목 변경
            document.title = settings.site_name;
            
            console.log('🌐 전역 설정 로드:', settings);
        } catch (error) {
            console.error('전역 설정 조회 실패:', error);
        }
    };

    useEffect(() => {
        fetchSettings();
    }, []);

    const refreshSettings = async () => {
        await fetchSettings();
    };

    return (
        <SettingsContext.Provider value={{ siteSettings, refreshSettings }}>
            {children}
        </SettingsContext.Provider>
    );
};

export default SettingsContext;
